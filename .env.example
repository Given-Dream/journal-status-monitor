# IEEE ScholarOne. Leave all three empty if you do not use IEEE.
IEEE_EMAIL=your_ieee_email@example.com
IEEE_PASSWORD=your_ieee_password
IEEE_URL=https://mc.manuscriptcentral.com/tie-ieee

# Elsevier Editorial Manager. Leave all three empty if you do not use Elsevier.
ELSEVIER_EMAIL=your_elsevier_email@example.com
ELSEVIER_PASSWORD=your_elsevier_password
ELSEVIER_URL=https://www.editorialmanager.com/your-journal

# Notification email. EMAIL_RECEIVER supports comma-separated recipients.
EMAIL_SENDER=your_sender_email@qq.com
EMAIL_PASSWORD=your_smtp_authorization_code
EMAIL_RECEIVER=your_receiver@example.com,another_receiver@example.com

# Optional SMTP override. If omitted, common providers are inferred from EMAIL_SENDER.
# SMTP_SERVER=smtp.qq.com
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465

# Runtime options
HEADLESS=true
DATA_FILE=data/manuscripts.json
RETENTION_DAYS=30
FAIL_ON_EMPTY=false
SAVE_DEBUG_ARTIFACTS=true

# Terminal-status archival.
# Accepted/published/rejected/withdrawn articles are archived after the first terminal status is recorded.
ARCHIVE_TERMINAL=true
INCLUDE_ARCHIVED_IN_REPORT=false
# TERMINAL_STATUS_KEYWORDS=accept,accepted,published,reject,rejected,withdrawn